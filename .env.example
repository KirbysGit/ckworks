# Resend API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Must be a sender verified in Resend, usually on your verified domain.
# Examples:
# CKWORKS_INQUIRY_FROM_EMAIL="CK Works <hello@ckworks.studio>"
# CKWORKS_INQUIRY_FROM_EMAIL="CK Works <inquiries@ckworks.studio>"
CKWORKS_INQUIRY_FROM_EMAIL="CK Works <hello@ckworks.studio>"

# Comma-separated inboxes that should receive project inquiries.
CKWORKS_INQUIRY_TO_EMAIL=hello@ckworks.co

# Optional comma-separated copies.
CKWORKS_INQUIRY_CC_EMAIL=
CKWORKS_INQUIRY_BCC_EMAIL=
